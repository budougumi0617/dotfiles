# Config generated by Ghostty Config

theme = Catppuccin Mocha
window-padding-x = 10
window-padding-y = 5
window-padding-balance = true
window-theme = ghostty
background-opacity = 0.95
background-blur-radius = 2
macos-titlebar-style = transparent
# Optキーを使えるようにする
macos-option-as-alt = true
# Shift+Enterで改行
keybind = shift+enter=text:\x1b[13;2u
copy-on-select = clipboard
shell-integration-features = ssh-terminfo,ssh-env

# デフォルトで起動時にtmuxを起動する
# command=/opt/homebrew/bin/tmux new -t terminal -s "terminal-$(tmux list-clients | grep terminal- | wc -l)" -A
# コマンドが終了したら表示内容を確認しておきたい
# wait-after-command = true
